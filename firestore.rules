rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin(request.auth.uid);
      allow create: if request.auth.uid != null;
      allow update, delete: if request.auth.uid == userId || isAdmin(request.auth.uid);
    }

    match /students/{docId} {
      allow read: if request.auth != null;
      allow create, update: if hasRole(['admin', 'scolarite', 'direction']);
      allow delete: if hasRole(['admin', 'direction']);
    }

    match /candidatures/{docId} {
      allow read: if hasRole(['admin', 'scolarite', 'direction']);
      allow create: if request.auth == null;
      allow update: if hasRole(['admin', 'scolarite']);
      allow delete: if hasRole(['admin']);
    }

    match /edt/{docId} {
      allow read: if request.auth != null;
      allow create, update: if hasRole(['admin', 'direction']);
      allow delete: if hasRole(['admin']);
    }

    match /intervenants/{docId} {
      allow read: if request.auth != null;
      allow create, update: if hasRole(['admin', 'direction']);
      allow delete: if hasRole(['admin']);
    }

    match /modules/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if hasRole(['admin', 'direction']);
    }

    match /planning/{docId} {
      allow read: if request.auth != null;
      allow create, update: if hasRole(['admin', 'direction']);
      allow delete: if hasRole(['admin']);
    }

    match /logs_audit/{docId} {
      allow read: if hasRole(['admin']);
      allow create: if request.auth != null;
      allow delete: if hasRole(['admin']);
    }

    function isAdmin(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }

    function hasRole(roles) {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }
  }
}
